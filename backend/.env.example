# Server Config
PORT=5000
NODE_ENV=development

# Database Config
MONGODB_URI=mongodb://localhost:27017/hms_db

# Security / JWT Keys
ACCESS_TOKEN_SECRET=your_super_secret_access_key_12345!
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key_54321!
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# CORS
ALLOWED_CLIENT_ORIGIN=http://localhost:5173

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP Mail Server Config
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=hms-alerts@hospital.com

# Admin Setup Configuration
DEFAULT_SUPERADMIN_EMAIL=superadmin@hms.com
DEFAULT_SUPERADMIN_PASSWORD=SuperAdmin123!
